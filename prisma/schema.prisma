generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
  engineType    = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id                 String       @id @default(cuid())
  ruc                String       @unique
  dv                 String
  razonSocial        String
  nombreComercial    String?
  direccion          String
  telefono           String?
  email              String?
  logo               String?
  ambienteDgi        String       @default("1")
  certificadoDgi     String?
  usuarioPac         String?
  passwordPac        String?
  planType           String       @default("free")
  fiscalEnabled      Boolean      @default(false)
  subscriptionStatus String       @default("active")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  webhookToken       String?
  webhookUrl         String?
  whatsappPhone      String?
  whatsappToken      String?
  cajas              Caja[]
  clientes           Cliente[]
  cotizaciones       Cotizacion[]
  facturas           Factura[]
  pagos              Pago[]
  productos          Producto[]
  secuencias         Secuencia[]
  sucursales         Sucursal[]
  usuarios           Usuario[]

  @@index([createdAt])
}

model Sucursal {
  id           String       @id @default(cuid())
  empresaId    String
  codigo       String
  nombre       String
  direccion    String
  activa       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  cajas        Caja[]
  cotizaciones Cotizacion[]
  facturas     Factura[]
  secuencias   Secuencia[]
  empresa      Empresa      @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, codigo])
  @@index([empresaId])
}

model Caja {
  id           String       @id @default(cuid())
  empresaId    String
  sucursalId   String
  codigo       String
  nombre       String
  activa       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  empresa      Empresa      @relation(fields: [empresaId], references: [id])
  sucursal     Sucursal     @relation(fields: [sucursalId], references: [id])
  cotizaciones Cotizacion[]
  facturas     Factura[]
  secuencias   Secuencia[]

  @@unique([sucursalId, codigo])
  @@index([empresaId])
}

model Secuencia {
  id            String   @id @default(cuid())
  empresaId     String
  sucursalId    String
  cajaId        String
  tipoDocumento String
  ultimoNumero  Int      @default(0)
  caja          Caja     @relation(fields: [cajaId], references: [id])
  empresa       Empresa  @relation(fields: [empresaId], references: [id])
  sucursal      Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([empresaId, sucursalId, cajaId, tipoDocumento])
}

model Usuario {
  id           String       @id @default(cuid())
  empresaId    String
  email        String       @unique
  passwordHash String
  nombre       String
  rol          String       @default("vendedor")
  activo       Boolean      @default(true)
  googleId     String?      @unique
  avatar       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  lastLogin    DateTime?
  auditorias   Auditoria[]
  cotizaciones Cotizacion[]
  facturas     Factura[]    @relation("FacturaCreador")
  pagos        Pago[]
  empresa      Empresa      @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
}

model Cliente {
  id              String       @id @default(cuid())
  empresaId       String
  tipoRuc         String
  ruc             String
  dv              String?
  razonSocial     String
  nombreComercial String?
  direccion       String?
  email           String?
  telefono        String?
  limiteCredito   Decimal      @default(0)
  saldoPendiente  Decimal      @default(0)
  saldoAFavor     Decimal      @default(0)
  condicionPago   String       @default("Contado")
  estado          String       @default("activo")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  empresa         Empresa      @relation(fields: [empresaId], references: [id])
  cotizaciones    Cotizacion[]
  facturas        Factura[]
  pagos           Pago[]

  @@unique([empresaId, ruc])
  @@index([empresaId])
}

model Producto {
  id               String           @id @default(cuid())
  empresaId        String
  codigoInterno    String
  codigoBarras     String?
  descripcion      String
  descripcionLarga String?
  costoUnitario    Decimal
  precioVenta      Decimal
  codigoTasaItbms  String           @default("00")
  unidadMedida     String           @default("UND")
  activo           Boolean          @default(true)
  stockActual      Int              @default(0)
  stockMinimo      Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  imagenUrl        String?
  cotizacionItems  CotizacionItem[]
  items            FacturaItem[]
  empresa          Empresa          @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, codigoInterno])
  @@index([empresaId])
}

model Factura {
  id               String        @id @default(cuid())
  empresaId        String
  sucursalId       String
  cajaId           String
  clienteId        String
  creadorId        String
  tipoDocumento    String
  numeroSecuencial Int
  numeroCompleto   String        @unique
  fechaEmision     DateTime      @default(now())
  fechaVencimiento DateTime?
  subtotal         Decimal
  totalDescuento   Decimal       @default(0)
  totalItbms       Decimal
  totalNeto        Decimal
  totalPagado      Decimal       @default(0)
  saldoPendiente   Decimal
  estadoDgi        String        @default("borrador")
  cufe             String?
  qrUrl            String?
  xmlContent       String?
  fechaAceptacion  DateTime?
  errorDgi         String?
  facturaOrigenId  String?
  motivoAnulacion  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  caja             Caja          @relation(fields: [cajaId], references: [id])
  cliente          Cliente       @relation(fields: [clienteId], references: [id])
  creador          Usuario       @relation("FacturaCreador", fields: [creadorId], references: [id])
  empresa          Empresa       @relation(fields: [empresaId], references: [id])
  facturaOrigen    Factura?      @relation("NotasCredito", fields: [facturaOrigenId], references: [id])
  notasCredito     Factura[]     @relation("NotasCredito")
  sucursal         Sucursal      @relation(fields: [sucursalId], references: [id])
  items            FacturaItem[]
  pagos            Pago[]

  @@index([empresaId, fechaEmision])
  @@index([clienteId])
  @@index([estadoDgi])
  @@index([empresaId])
  @@index([empresaId, tipoDocumento])
  @@index([creadorId])
}

model FacturaItem {
  id              String   @id @default(cuid())
  facturaId       String
  productoId      String
  descripcion     String
  cantidad        Decimal
  precioUnitario  Decimal
  costoUnitario   Decimal
  descuento       Decimal  @default(0)
  codigoTasaItbms String
  montoItbms      Decimal
  montoTotal      Decimal
  factura         Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  producto        Producto @relation(fields: [productoId], references: [id])

  @@index([facturaId])
  @@index([productoId])
}

model Pago {
  id            String   @id @default(cuid())
  empresaId     String
  facturaId     String
  clienteId     String
  usuarioId     String
  fechaPago     DateTime @default(now())
  monto         Decimal
  metodoPago    String
  referencia    String?
  montoAplicado Decimal
  montoCredito  Decimal  @default(0)
  createdAt     DateTime @default(now())
  cliente       Cliente  @relation(fields: [clienteId], references: [id])
  empresa       Empresa  @relation(fields: [empresaId], references: [id])
  factura       Factura  @relation(fields: [facturaId], references: [id])
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([empresaId])
  @@index([facturaId])
  @@index([clienteId])
  @@index([fechaPago])
}

model Auditoria {
  id           String   @id @default(cuid())
  usuarioId    String
  entidad      String
  entidadId    String
  accion       String
  datosAntes   Json?
  datosDespues Json?
  ip           String?
  createdAt    DateTime @default(now())
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([entidad, entidadId])
  @@index([createdAt])
}

model Cotizacion {
  id             String           @id @default(cuid())
  empresaId      String
  sucursalId     String
  cajaId         String
  clienteId      String
  creadorId      String
  numero         String           @unique
  fechaEmision   DateTime         @default(now())
  validaHasta    DateTime
  subtotal       Decimal
  totalDescuento Decimal          @default(0)
  totalItbms     Decimal
  totalNeto      Decimal
  estado         String           @default("borrador")
  facturaId      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  caja           Caja             @relation(fields: [cajaId], references: [id])
  cliente        Cliente          @relation(fields: [clienteId], references: [id])
  creador        Usuario          @relation(fields: [creadorId], references: [id])
  empresa        Empresa          @relation(fields: [empresaId], references: [id])
  sucursal       Sucursal         @relation(fields: [sucursalId], references: [id])
  items          CotizacionItem[]

  @@index([empresaId, fechaEmision])
  @@index([clienteId])
}

model CotizacionItem {
  id              String     @id @default(cuid())
  cotizacionId    String
  productoId      String
  descripcion     String
  cantidad        Decimal
  precioUnitario  Decimal
  descuento       Decimal    @default(0)
  codigoTasaItbms String
  montoItbms      Decimal
  montoTotal      Decimal
  cotizacion      Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  producto        Producto   @relation(fields: [productoId], references: [id])
}
